# SPARCAL Spatial-SNV Viewer — study configuration
# Drag this file into the viewer (or File > Open) to load the study.
# All `files:` paths are relative to the directory that contains THIS config
# file, so the whole folder is self-contained and can be moved/copied freely.

project: SPARCAL
study: DCIS_2
genome: GRCh38            # no-"chr" contig naming (e.g. 10_100155535_G_T)

files:
  # pandas-pickled uint8 DataFrame. rows = spot barcodes (e.g. AAAC...-1),
  # cols = SNV keys "{chrom}_{pos}_{ref}_{alt}" (no "chr"), value = presence (alt>0).
  snv_matrix: snv_matrix.pkl

  # Visium spatial/tissue_positions.csv:
  # barcode,in_tissue,array_row,array_col,pxl_row_in_fullres,pxl_col_in_fullres
  tissue_positions: tissue_positions.csv

  # Background high-resolution tissue image for the spatial view.
  hires_image: tissue_hires_image.png

  # Visium scalefactors_json.json (holds tissue_hires_scalef, spot_diameter_fullres).
  scalefactors: scalefactors_json.json

  # Tumor-region definitions saved/edited by the app. Long format:
  #   region_name,barcode  (one row per spot in a region)
  # Created empty here; the app writes regions back to this file.
  tumor_groups: tumor_groups.csv

  # Generated variant groups (the SNV name-tags under each region). Long format:
  #   region_name,group_name,group_type,snv_key
  # group_type is one of: exclusive | general | exclusive_threshold | selection
  # Created empty here; the app writes groups back to this file.
  variant_groups: variant_groups.csv

  # Center (seed) barcode of each AUTO-generated tumor region. Long format:
  #   region_name,barcode
  # Written by the app when "Auto" regions are created; the center is highlighted
  # (star marker) when such a region is selected. Defaults to tumor_centers.csv.
  tumor_centers: tumor_centers.csv

  # Optional per-spot coverage (barcode,total_umi) used to coverage-normalize the
  # SNV burden for "Auto" tumor-region detection. Generate from raw SpaceRanger
  # output with tools/make_spot_coverage.py. If omitted, raw burden is used.
  spot_coverage: spot_coverage.csv

# How to map spots onto the hires image:
#   x_pixel = pxl_col_in_fullres * tissue_hires_scalef
#   y_pixel = pxl_row_in_fullres * tissue_hires_scalef
image:
  x_column: pxl_col_in_fullres
  y_column: pxl_row_in_fullres
  scalef_key: tissue_hires_scalef
  spot_diameter_key: spot_diameter_fullres
  in_tissue_only: true     # plot only spots with in_tissue == 1

# Defaults for the "generate" variant-grouping actions (second column).
# Thresholds are percentages of spots within / outside a tumor region.
variant_grouping:
  general_min_fraction: 80   # "general": present in > this % of region spots
  exclusive_inside_min: 80   # "exclusive by threshold": > this % inside region ...
  exclusive_outside_max: 20  # ... and < this % outside region
